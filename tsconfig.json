{
  "compilerOptions": {
    "jsx": "react",
    "target": "es6",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true // Ensures compatibility with allowImportingTsExtensions
  },
  "include": ["src/**/*"] // Ensure all files in src are included
}